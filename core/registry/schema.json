{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JarvisOS iPhone 6 Capability Registry",
  "type": "object",
  "required": ["version", "target_device", "capabilities"],
  "properties": {
    "version": { "type": "string" },
    "target_device": { "type": "string" },
    "capabilities": {
      "type": "array",
      "minItems": 400,
      "items": {
        "type": "object",
        "required": [
          "id",
          "family",
          "name",
          "example_voice_phrases",
          "mode",
          "required_hardware",
          "risk_level",
          "permission_required",
          "implementation_notes",
          "test_idea"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "family": { "type": "string", "minLength": 2 },
          "name": { "type": "string", "minLength": 3 },
          "example_voice_phrases": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string", "minLength": 2 }
          },
          "mode": { "enum": ["offline", "online", "dock", "hybrid"] },
          "required_hardware": {
            "type": "array",
            "items": { "type": "string" }
          },
          "risk_level": { "enum": ["low", "medium", "high"] },
          "permission_required": { "type": "string", "minLength": 2 },
          "implementation_notes": { "type": "string", "minLength": 8 },
          "test_idea": { "type": "string", "minLength": 8 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
