<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.jarvisos.daemon</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/jarvisd</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/var/mobile/Library/JarvisOS/logs/daemon.out</string>
  <key>StandardErrorPath</key>
  <string>/var/mobile/Library/JarvisOS/logs/daemon.err</string>
</dict>
</plist>
